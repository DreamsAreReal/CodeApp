{
  "name": "codex-mini-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Telegram Mini App — deep C# fundamentals refresher for seniors (walking skeleton).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:deploy": "tsc --noEmit && VITE_API_BASE= vite build --outDir dist-deploy --emptyOutDir",
    "deploy:pack": "npm run build:deploy && rm -rf ../backend/Codex.Backend/wwwroot && cp -r dist-deploy ../backend/Codex.Backend/wwwroot",
    "preview": "vite preview --port 4173",
    "verify": "node verify/run.mjs",
    "verify:all": "node verify/all.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "playwright": "^1.61.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/onest": "^5.2.11",
    "@fontsource/rubik": "^5.2.8"
  }
}
