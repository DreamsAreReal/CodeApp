  "depth": {
    "intuition": [
      { "id": "i1", "text": "Хеш-таблица кладёт ключ в bucket по hash(key) % size — доступ в среднем O(1), не через перебор.", "source": "clrs-ch11", "status": "fact" }
    ],
    "mechanics": [
      { "id": "m1", "text": "Коллизия (два ключа в один bucket) решается цепочкой (separate chaining) или открытой адресацией.", "source": "clrs-ch11", "status": "fact" },
      { "id": "m2", "text": "При высоком факторе загрузки таблица делает resize и перехеширует все ключи — амортизированно O(1).", "source": "clrs-ch11", "status": "fact" },
      { "id": "m3", "text": ".NET Dictionary<TKey,TValue> — реализация хеш-таблицы с separate chaining.", "source": "ms-dictionary", "status": "fact" }
    ],
    "spec": [
      { "id": "s1", "text": "Средняя сложность поиска/вставки — O(1), худшая — O(n) при вырожденном хешировании (все ключи в одну цепочку).", "source": "clrs-ch11", "status": "fact" }
    ]
  },
  "edgeCases": [
    { "id": "e1", "text": "Плохой хеш (все ключи в один bucket) вырождает таблицу в связный список — поиск O(n).", "source": "clrs-ch11" }
  ],
  "misconceptions": [
    { "wrong": "Хеш-таблица всегда O(1).", "correction": "В среднем O(1); худший случай O(n) при коллизиях или атаке на хеш.", "source": "clrs-ch11" }
  ],
  "rationale": { "id": "r1", "text": "Хеш-таблица меняет память на скорость: массив bucket'ов + хеш дают почти константный доступ по ключу.", "source": "clrs-ch11" },

