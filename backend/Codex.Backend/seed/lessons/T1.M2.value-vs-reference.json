  "depth": {
    "intuition": [
      { "id": "i1", "text": "Value-тип содержит сам экземпляр; reference-тип содержит ссылку на объект на куче.", "source": "cs-value-types", "status": "fact" }
    ],
    "mechanics": [
      { "id": "m1", "text": "Присваивание value-типа копирует значение целиком: у struct семантика значения.", "source": "cs-struct", "status": "fact" },
      { "id": "m2", "text": "Присваивание reference-типа копирует ссылку: оба имени указывают на один объект.", "source": "cs-classes", "status": "fact" }
    ],
    "spec": [
      { "id": "s1", "text": "Value: «each variable has its own copy of the data». Reference: «two variables can reference the same object».", "source": "cs-reference-types", "status": "fact" }
    ]
  },
  "edgeCases": [
    { "id": "e1", "text": "struct: var b = a копирует значение; мутация b не трогает a.", "source": "cs-struct" },
    { "id": "e2", "text": "class: var b = a копирует ссылку; a и b смотрят на один объект.", "source": "cs-classes" }
  ],
  "misconceptions": [
    { "wrong": "var b = a всегда делает копию данных.", "correction": "Только для value-типов; для class копируется лишь ссылка на общий объект.", "source": "cs-value-types" }
  ],
  "rationale": { "id": "r1", "text": "Две категории типов определяют и размещение (стек/inline vs куча), и семантику копирования.", "source": "cs-value-types" },

