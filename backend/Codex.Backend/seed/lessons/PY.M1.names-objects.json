  "depth": {
    "intuition": [
      {
        "id": "i1",
        "text": "Имя ссылается на объект; присваивание привязывает имя, а не копирует значение. Тип живёт у объекта, не у имени.",
        "source": "py-datamodel",
        "status": "fact"
      }
    ],
    "mechanics": [
      {
        "id": "m1",
        "text": "b = a создаёт второе имя того же объекта (aliasing): мутация через любое имя видна через все остальные; a is b == True.",
        "source": "py-datamodel",
        "status": "fact"
      },
      {
        "id": "m2",
        "text": "Дефолт аргумента вычисляется один раз — при def — и живёт в __defaults__ объекта-функции; mutable-дефолт копит состояние между вызовами.",
        "source": "py-defaults",
        "status": "fact"
      },
      {
        "id": "m3",
        "text": "Объект живёт по счётчику ссылок (ноль — освобождается немедленно); кольца ссылок находит циклический сборщик, дополняющий refcounting.",
        "source": "py-gc",
        "status": "fact"
      }
    ],
    "spec": [
      {
        "id": "s1",
        "text": "«Every object has an identity, a type and a value.» (дословно, reference/datamodel)",
        "source": "py-datamodel",
        "status": "fact"
      }
    ]
  },
  "edgeCases": [
    {
      "id": "e1",
      "text": "Неизменяемость tuple — мелкая: t = (1, [2, 3]); t[1].append(4) работает → (1, [2, 3, 4]); TypeError только на перепривязке слота t[0] = 9.",
      "source": "py-datamodel"
    },
    {
      "id": "e2",
      "text": "CPython кэширует int от -5 до 256: identity малых int — деталь реализации, is на числах — баг; is оставь для None (PEP 8).",
      "source": "py-int-cache"
    }
  ],
  "misconceptions": [
    {
      "wrong": "Переменная в Python хранит значение.",
      "correction": "Имя ссылается на объект: все значения — объекты в куче CPython, присваивание лишь привязывает имя. Отсюда aliasing, mutable default и правила is/==.",
      "source": "py-datamodel"
    },
    {
      "wrong": "items=[] в сигнатуре даёт свежий список на каждый вызов.",
      "correction": "Дефолт вычисляется один раз — при def («Default values are created exactly once, when the function is defined»); все вызовы делят один список.",
      "source": "py-faq-defaults"
    }
  ],
  "rationale": {
    "id": "r1",
    "text": "Единая модель «имена → объекты» объясняет весь фундамент трека: aliasing, mutable default, refcount и поведение is — не как отдельные факты, а как следствия привязки имён.",
    "source": "py-datamodel"
  },
