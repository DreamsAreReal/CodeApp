  "depth": {
    "intuition": [
      { "id": "i1", "text": "Лишние позиционные аргументы упаковываются в tuple (*args), лишние именованные — в dict (**kwargs); * и ** в вызове распаковывают контейнеры обратно в аргументы.", "source": "py-tut-args", "status": "fact" }
    ],
    "mechanics": [
      { "id": "m1", "text": "find_element(*locator) — обычная распаковка кортежа в позиционные аргументы, не синтаксис Selenium.", "source": "py-tut-unpack", "status": "fact" },
      { "id": "m2", "text": "Порядок параметров один: позиционные → *args → keyword-only → **kwargs; нарушение — SyntaxError на компиляции.", "source": "py-tut-args", "status": "fact" },
      { "id": "m3", "text": "first, *rest = ... собирает в rest СПИСОК (PEP 3132); *args в сигнатуре — кортеж.", "source": "pep3132", "status": "fact" }
    ],
    "spec": [
      { "id": "s1", "text": "«These arguments will be wrapped up in a tuple.» (Tutorial, дословно)", "source": "py-tut-args", "status": "fact" }
    ]
  },
  "edgeCases": [
    { "id": "e1", "text": "Параметры после *args — keyword-only: передать их позиционно нельзя.", "source": "py-tut-args" },
    { "id": "e2", "text": "*rest при присваивании — list, *args в сигнатуре — tuple: рифма-ловушка собеса.", "source": "pep3132" }
  ],
  "misconceptions": [
    { "wrong": "*locator в find_element(*locator) — специальный синтаксис Selenium.", "correction": "Это распаковка языка: * раскрывает список/кортеж в позиционные аргументы, ** — словарь в именованные; работает в любом вызове.", "source": "py-tut-unpack" }
  ],
  "rationale": { "id": "r1", "text": "Пара «упаковка в кадре / распаковка в вызове» — фундамент универсальных wrapper-ов: def wrapper(*args, **kwargs) пробрасывает любую сигнатуру — на этом стоят декораторы и фикстуры следующих уроков.", "source": "py-tut-args" },

