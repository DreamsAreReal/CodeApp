    "python": "3.12.13"
  },
  "reviewBy": "2026-10-01",
  "status": "published",
  "order": 11,
  "depth": {
    "intuition": [
      {
        "id": "i1",
        "text": "Список ищет сканом (O(n)); set/dict считают hash(x) и прыгают в бакет — в среднем O(1), worst-case O(n) при коллизиях.",
        "source": "py-wiki-tc",
        "status": "fact"
      }
    ],
    "mechanics": [
      {
        "id": "m1",
        "text": "Ключ dict / элемент set обязан быть хэшируемым: хэш не меняется за время жизни объекта; равные объекты обязаны иметь равный хэш.",
        "source": "py-glossary-hashable",
        "status": "fact"
      },
      {
        "id": "m2",
        "text": "tuple хэшируем, только если внутри лишь хэшируемое: (1, [2]) в роли ключа падает TypeError.",
        "source": "py-glossary-hashable",
        "status": "fact"
      },
      {
        "id": "m3",
        "text": "Set-операции — язык диффов: expected - actual (пропало), actual - expected (лишнее), & (пересечение), ^ (расхождение).",
        "source": "py-tut-ds",
        "status": "fact"
      }
    ],
    "spec": [
      {
        "id": "s1",
        "text": "«the insertion-order preservation nature of dict objects has been declared to be an official part of the Python language spec» (What's New 3.7, дословно)",
        "source": "py-whatsnew37",
        "status": "fact"
      }
    ]
  },
  "edgeCases": [
    {
      "id": "e1",
      "text": "Порядок set спекой не гарантирован — assert по распечатке set = флак; порядок dict гарантирован с 3.7.",
      "source": "py-whatsnew37"
    },
    {
      "id": "e2",
      "text": "x in list внутри цикла по n элементам — O(n²); один set(...) на входе убирает полку сложности.",
      "source": "py-wiki-tc"
    }
  ],
  "misconceptions": [
    {
      "wrong": "Разница list/set/tuple — «изменяемый / неизменяемый / неупорядоченный».",
      "correction": "Senior-ответ идёт через хэш-таблицу: set ради уникальности и O(1)-поиска; tuple хэшируем, поэтому может быть ключом dict; list — нет.",
      "source": "py-glossary-hashable"
    },
    {
      "wrong": "set поиск — «просто O(1)».",
      "correction": "В среднем O(1); worst-case O(n) при коллизиях — стандартный follow-up собеса.",
      "source": "py-wiki-tc"
    }
  ],
  "rationale": {
    "id": "r1",
    "text": "Одна модель «hash → бакет» объясняет выбор структуры, запрет mutable-ключей, tuple-ловушку и set-диффы для тестов — не как отдельные факты, а как следствия контракта хэшируемости.",
    "source": "py-glossary-hashable"
  },
